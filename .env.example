# Azure Active Directory Configuration
# Copy this file to .env.local and configure your values

# Optional: Override the default tenant ID
# If not provided, uses 'common' endpoint for multi-tenant authentication
# NEXT_PUBLIC_AZURE_TENANT_ID=your-azure-tenant-id-here

# Optional: Override client ID (normally not needed - uses Azure CLI public client by default)
# NEXT_PUBLIC_AZURE_CLIENT_ID=your-custom-client-id-here

# Optional: Enable demo mode for testing without Azure AD
DEMO_MODE=false

# Optional: Custom app branding
APP_NAME="Griphook"
